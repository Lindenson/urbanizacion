# Copia este archivo a .env y cambia las contraseñas antes de usarlo en producción.
#   cp .env.example .env

# Base de datos
MYSQL_DATABASE=wordpress
MYSQL_USER=wpuser
MYSQL_PASSWORD=cambia-esta-contrasena
MYSQL_ROOT_PASSWORD=cambia-esta-contrasena-root

# Puerto en el que se publica WordPress en la máquina anfitriona
WP_PORT=5000
